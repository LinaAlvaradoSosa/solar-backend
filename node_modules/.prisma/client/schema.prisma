generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ServiceAreaStatus {
  WESTERN_CO_TARGET
  OTHER_CO
  OUT_OF_STATE
  UNKNOWN
}

enum LeadBucket {
  TARGET
  OTHER_LEAD
}

enum LeadStatus {
  STARTED
  COMPLETED
  NOT_INTERESTED
}

model Lead {
  id                String            @id @default(cuid())
  fullName          String
  email             String
  phone             String?
  propertyType      String?
  monthlyBill       String?
  addressRaw        String
  city              String?
  state             String?
  zipCode           String
  serviceType       String?
  houseSpecs        String?
  seriousness       Int
  energyProvider    String?
  consentGiven      Boolean
  consentText       String?
  consentedAt       DateTime?
  serviceAreaStatus ServiceAreaStatus
  leadBucket        LeadBucket
  status            LeadStatus        @default(COMPLETED)
  isHotLead         Boolean           @default(false)
  emailedAt         DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  events LeadEvent[]
}

model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  eventType String
  payload   String?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
